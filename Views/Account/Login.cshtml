@model UtilityManagement.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login</title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <!-- JS (ORDER IS IMPORTANT) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            overflow: hidden;
        }

        .login-page {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            background-image: url('/images/UtilityManagement_BG.png');
            background-repeat: no-repeat;
            background-position: center top;
            background-size: cover;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            .login-page::before {
                content: "";
                position: absolute;
                inset: 0;
                background: rgba(0,0,0,0.55);
                z-index: 1;
            }

        .login-card {
            position: relative;
            z-index: 2;
            width: 500px;
            padding: 35px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 10px 35px rgba(0,0,0,0.3);
            color: white;
            /* RIGHT SHIFT (your request) */
            transform: translateX(80px);
        }

        .logo {
            display: block;
            margin: 0 auto 10px auto;
            max-width: 180px;
        }

        .login-title {
            font-weight: 700;
            text-align: center;
            margin: 0;
        }

        .login-subtitle {
            text-align: center;
            font-size: 14px;
            margin-bottom: 20px;
            color: rgba(255,255,255,0.85);
        }

        .form-control {
            background: rgba(255,255,255,0.15);
            border: none;
            color: white;
        }

            .form-control::placeholder {
                color: rgba(255,255,255,0.7);
            }

            .form-control:focus {
                box-shadow: none;
                border: 1px solid #0d6efd;
                background: rgba(255,255,255,0.2);
                color: white;
            }

        label {
            color: rgba(255,255,255,0.9);
            font-size: 14px;
        }

        .btn-login {
            background: #0d6efd;
            border: none;
            font-weight: 600;
        }

            .btn-login:hover {
                background: #0b5ed7;
            }

        /* TOAST FIX */
        #toast-container {
            z-index: 999999 !important;
        }

        .toast-success {
            background-color: #28a745 !important;
            color: white !important;
            font-weight: 600;
        }

        .toast-error {
            background-color: #dc3545 !important;
            color: white !important;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="login-page">

        <div class="login-card">

            <!-- LOGO -->
            <img src="~/images/cotton_club_bd_ltd.jpg" class="logo" />

            <!-- TITLE -->
            <h5 class="login-title">Welcome to Utility Management</h5>
            <p class="login-subtitle">Please login to continue</p>

            <!-- FORM -->
            <form asp-action="Login" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="mb-3">
                    <label>Username</label>
                    <input asp-for="Email" class="form-control" placeholder="Enter username" />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label">Remember Me</label>
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Login
                </button>

            </form>

        </div>

    </div>

    <!-- TOAST SCRIPT -->
    <script>
        $(function () {

            toastr.options = {
                closeButton: true,
                progressBar: true,
                positionClass: "toast-top-right",
                timeOut: 1000,
                newestOnTop: true,
                preventDuplicates: true
            };

            var successMessage = "@(TempData["SuccessMessage"] as string ?? "")";
            var errorMessage = "@(TempData["ErrorMessage"] as string ?? "")";

            if (successMessage.length > 0) {
                toastr.success(successMessage, "Success");
            }

            if (errorMessage.length > 0) {
                toastr.error(errorMessage, "Error");
            }
        });
    </script>

</body>
</html>