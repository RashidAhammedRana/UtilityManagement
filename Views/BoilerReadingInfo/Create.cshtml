                        </div>

                        <div class="stepper">

                            <div id="stepCircle1" class="step active">
                                1
                            </div>

                            <div id="stepLine" class="line"></div>

                            <div id="stepCircle2" class="step">
                                2
                            </div>
                        </div>

                        <div id="step1" class="wizard-step active">

                            <div class="section-title">

                                Basic Information

                            </div>

                        <div class="row g-3">

                            <!-- Trdate -->
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <label asp-for="Trdate" class="form-label">
