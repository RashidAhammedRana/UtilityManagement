                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="NgMHr" class="form-label">
                                        NG (m3/Hr)<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="NgMHr" class="form-control" readonly />
                                    <span asp-validation-for="NgMHr" class="text-danger"></span>
                                </div>

                            <!-- CngConM -->
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <label asp-for="CngConM" class="form-label">
                                    CNG Cons.(m3)<span class="text-danger">*</span>
                                </label>
                                <input asp-for="CngConM" class="form-control" />
                                <span asp-validation-for="CngConM" class="text-danger"></span>
                            </div>
                            <!-- CngRh -->
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <label asp-for="CngRh" class="form-label">
                                    CNG RH<span class="text-danger">*</span>
                                </label>
                                <input asp-for="CngRh" class="form-control" />
                                <span asp-validation-for="CngRh" class="text-danger"></span>
                            </div>
                            <!-- CngMHr -->
