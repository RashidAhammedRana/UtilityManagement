                                </label>
                                <input asp-for="DslConLtr" class="form-control" />
                                <span asp-validation-for="DslConLtr" class="text-danger"></span>
                            </div>

                            <!-- DslRh -->
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <label asp-for="DslRh" class="form-label">
                                    Diesel RH <span class="text-danger">*</span>
                                </label>
                                <input asp-for="DslRh" class="form-control" />
                                <span asp-validation-for="DslRh" class="text-danger"></span>
                            </div>

                            <!-- DslLtrHr -->
                                <!-- DslLtrHr=DslConLtr/DslRh -->
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <label asp-for="DslLtrHr" class="form-label">
                                    Diesel Ltr/Hr<span class="text-danger">*</span>
                                </label>
                                <input asp-for="DslLtrHr" class="form-control"readonly />
                                <span asp-validation-for="DslLtrHr" class="text-danger"></span>
                            </div>
                                <!-- NgConM -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="NgConM" class="form-label">
                                        NG Cons.(m3)<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="NgConM" class="form-control" />
                                    <span asp-validation-for="NgConM" class="text-danger"></span>
                                </div>
                                <!-- NgRh -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="NgRh" class="form-label">
                                        NG RH<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="NgRh" class="form-control" />
                                    <span asp-validation-for="NgRh" class="text-danger"></span>
                                </div>
                                <!-- MHr -->
