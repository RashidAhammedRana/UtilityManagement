@model UtilityManagement.Models.TblBoilerRmsRoom

@{
    ViewData["Title"] = "Edit Boiler RMS Room Reading";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Edit Boiler RMS Room Reading</h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Trid" />
                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row g-3">

                            <!-- Trdate -->
                            <div class="col-md-6">
                                <label asp-for="Trdate" class="form-label">
                                    Date <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Trdate" type="date" class="form-control" />

                                <span asp-validation-for="Trdate" class="text-danger"></span>
                            </div>

                            <!-- Equipment -->
                            <div class="col-md-6">
                                <label asp-for="Eqid" class="form-label">
                                    Equipment <span class="text-danger">*</span>
                                </label>

                                <select asp-for="Eqid" asp-items="ViewBag.EquipmentList" class="form-select">
                                    <option value="">-- Select Equipment --</option>
                                </select>

                                <span asp-validation-for="Eqid" class="text-danger"></span>
                            </div>

                            <!-- NgConsumption -->
                            <div class="col-md-6">
                                <label asp-for="NgConsumption" class="form-label">
                                    NG Consumption(m3)<span class="text-danger">*</span>
                                </label>
                                <input asp-for="NgConsumption" class="form-control" />
                                <span asp-validation-for="NgConsumption" class="text-danger"></span>
                            </div>

                            <!-- NG(Tk/m3) -->
                            <div class="col-md-6">
                                <label asp-for="NgTk" class="form-label">
                                    NG(Tk/m3) <span class="text-danger">*</span>
                                </label>
                                <input asp-for="NgTk" class="form-control" readonly />
                                <span asp-validation-for="NgTk" class="text-danger"></span>
                            </div>

                            <!-- ToalRh -->
                            <div class="col-md-6">
                                <label asp-for="ToalRh" class="form-label">
                                    Total RH<span class="text-danger">*</span>
                                </label>
                                <input asp-for="ToalRh" class="form-control" />
                                <span asp-validation-for="ToalRh" class="text-danger"></span>
                            </div>

                            <!-- GenerationKwh -->
                            <div class="col-md-6">
                                <label asp-for="TkHr" class="form-label">
                                    TK/Hr<span class="text-danger">*</span>
                                </label>
                                <input asp-for="TkHr" class="form-control" readonly />
                                <span asp-validation-for="TkHr" class="text-danger"></span>
                            </div>
                            <!-- NG Consumtion/Hr -->
                            <div class="col-md-6">
                                <label asp-for="NgConsumptionHr" class="form-label">
                                    NG Consumtion/Hr<span class="text-danger">*</span>
                                </label>
                                <input asp-for="NgConsumptionHr" class="form-control" readonly />
                                <span asp-validation-for="NgConsumptionHr" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="BoilerRmsRoomInfoList"
                               class="btn btn-outline-secondary">
                                ← Back
                            </a>

                            <button type="submit"
                                    class="btn btn-success px-4">
                                Update Reading
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const ngConsumption = document.getElementById("NgConsumption");
        const ngTk = document.getElementById("NgTk");
        const totalRh = document.getElementById("ToalRh");
        const tkHr = document.getElementById("TkHr");
        const ngConsumptionHr = document.getElementById("NgConsumptionHr");

        const ngRate = parseFloat('@ViewBag.NgRate') || 0;


        function calculateValues() {

            let consumption = parseFloat(ngConsumption.value) || 0;
            let rh = parseFloat(totalRh.value) || 0;


            // NG(Tk/m3)
            let totalNgTk = consumption * ngRate;

            ngTk.value = totalNgTk.toFixed(2);


            // TK/Hr
            if (rh > 0) {

                tkHr.value = (totalNgTk / rh).toFixed(2);

                ngConsumptionHr.value =
                    (consumption / rh).toFixed(2);

            }
            else {

                tkHr.value = "0.00";
                ngConsumptionHr.value = "0.00";

            }

        }


        // Change হলে calculate হবে
        ngConsumption.addEventListener("keyup", calculateValues);
        ngConsumption.addEventListener("change", calculateValues);

        totalRh.addEventListener("keyup", calculateValues);
        totalRh.addEventListener("change", calculateValues);


    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
