@model UtilityManagement.Models.TblCountryInfo

@{
    ViewData["Title"] = "Edit Country";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Edit Country Information</h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit" method="post">
                        <input asp-for="Cntid" type="hidden" />
                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row g-3">

                            <!-- Country Code -->
                            <div class="col-md-6">
                                <label asp-for="CntCode" class="form-label">
                                    Country Code
                                </label>
                                <input asp-for="CntCode" class="form-control" />
                            </div>
                            <!-- Country Name -->
                            <div class="col-md-6">
                                <label asp-for="CntName" class="form-label">
                                    Country Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="CntName" class="form-control" />
                                <span asp-validation-for="CntName" class="text-danger"></span>
                            </div>

                            <!-- Status -->
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">
                                    Status <span class="text-danger">*</span>
                                </label>

                                <select asp-for="Status" class="form-select">
                                    <option value="">-- Select Status --</option>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>

                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>

                            <!-- Remarks -->
                            <div class="col-md-6">
                                <label asp-for="Remarks" class="form-label">
                                    Remarks
                                </label>
                                <input asp-for="Remarks" class="form-control" />
                            </div>

                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="BuildingInfoList"
                               class="btn btn-outline-secondary">
                                ← Back
                            </a>

                            <button type="submit"
                                    class="btn btn-success px-4">
                                Update
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
