@model IEnumerable<UtilityManagement.Models.TblElectricityInterruptionInfo>

@{
    ViewData["Title"] = "Electricity Interruption Reading List";

    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;

    int pageSize = 15;
    int sl = (currentPage - 1) * pageSize;

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);

    bool canCreate = ViewBag.CanCreate ?? false;
    bool canEdit = ViewBag.CanEdit ?? false;
    bool canDelete = ViewBag.CanDelete ?? false;
}

<h2 class="text-center">Electricity Interruption Reading List</h2>

<p class="text-muted text-center">
    Total Records: <strong>@ViewBag.totalElectricityInterruptions</strong>
</p>

<!-- ================= HEADER ================= -->
<div class="d-flex justify-content-between align-items-center mb-3">

    <!-- SEARCH -->
    <form method="get"
          asp-action="ElectricityInterruptionInfoList"
          class="d-flex gap-2 align-items-center flex-grow-1">

        <input type="text"
               name="searchString"
               id="searchBox"
               value="@ViewBag.SearchString"
               class="form-control"
               placeholder="Search here..."
               style="max-width: 350px;" />

    </form>

    <!-- ACTION BUTTONS -->
    <div class="d-flex gap-2">

        @if (canCreate)
        {
            <a asp-action="Create" class="btn btn-primary">
                + Create
            </a>
        }

        <button type="button"
                class="btn btn-secondary"
                onclick="window.history.back();">
            Back
        </button>

    </div>

</div>

<!-- ================= TABLE ================= -->
<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">

        <thead class="table-dark text-center">
            <tr>
                <th style="width: 40px;">SL</th>
                <th style="width: 80px;">Date</th>
                <th style="width: 140px;">Company</th>
                <th style="width: 120px;">Department</th>
                <th style="width: 100px;">Power Off Time</th>
                <th style="width: 100px;">Power On Time</th>
                <th style="width: 90px;">Duration(Min)</th>
                <th style="width: 120px;">Interruption Type</th>
                <th style="width: 250px;">Reason</th>
                <th style="width: 80px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                sl++;

                <tr class="text-center">
                    <td>@sl</td>

                    <td>@item.Date?.ToString("dd-MM-yyyy")</td>

                    <td>@item.Company?.ComName</td>

                    <td>@item.Department?.DepartmentName</td>

                    <td>@item.PowerOffTime?.ToString("hh:mm tt")</td>

                    <td>@item.PowerOnTime?.ToString("hh:mm tt")</td>

                    <td>@item.DurationMin</td>

                    <td>@item.InterruptionType?.InterruptionTypeName</td>

                    <td>@item.Reason?.ReasonName</td>

                    <td>
                        <div class="btn-group btn-group-sm gap-2">

                            @if (canEdit)
                            {
                                <a asp-action="Edit"
                                   asp-route-id="@item.Eiid"
                                   class="btn btn-success">
                                    Edit
                                </a>
                            }

                            @if (canDelete)
                            {
                                <a asp-action="Delete"
                                   asp-route-id="@item.Eiid"
                                   class="btn btn-danger">
                                    Delete
                                </a>
                            }

                        </div>
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>

<!-- ================= PAGINATION ================= -->
<nav>
    <ul class="pagination justify-content-center flex-wrap">

        <!-- Prev -->
        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("ElectricityInterruptionInfoList", new { page = currentPage - 1, searchString = ViewBag.SearchString })">
                Previous
            </a>
        </li>

        <!-- Pages -->
        @for (int i = startPage; i <= endPage; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   href="@Url.Action("ElectricityInterruptionInfoList", new { page = i, searchString = ViewBag.SearchString })">
                    @i
                </a>
            </li>
        }

        <!-- Next -->
        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("ElectricityInterruptionInfoList", new { page = currentPage + 1, searchString = ViewBag.SearchString })">
                Next
            </a>
        </li>

    </ul>
</nav>

<!-- ================= AUTO SEARCH ================= -->
<script>
    let timer;

    const searchBox = document.getElementById("searchBox");

    searchBox.addEventListener("input", function () {

        clearTimeout(timer);

        timer = setTimeout(() => {

            let url = new URL(window.location.href);

            if (this.value) {
                url.searchParams.set("searchString", this.value);
            } else {
                url.searchParams.delete("searchString");
            }

            url.searchParams.set("page", 1);

            window.location.href = url.toString();

        }, 500);
    });

    // focus + cursor end
    window.onload = function () {
        if (searchBox) {
            searchBox.focus();
            let val = searchBox.value;
            searchBox.value = "";
            searchBox.value = val;
        }
    };
</script>