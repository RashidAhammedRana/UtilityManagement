@model IEnumerable<UtilityManagement.Models.TblEquipmentDetails>

@{
    ViewData["Title"] = "Equipment Details List";

    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;

    int pageSize = 15;
    int sl = (currentPage - 1) * pageSize;

    bool canCreate = ViewBag.CanCreate ?? false;
    bool canEdit = ViewBag.CanEdit ?? false;
    bool canDelete = ViewBag.CanDelete ?? false;
}

<h2>Equipment Details List</h2>

<p class="text-muted">
    Total Equipments: <strong>@ViewBag.TotalEquipmentDetails</strong>
</p>

<!-- ACTION BUTTONS -->
<div class="d-flex justify-content-end mb-3 gap-2">

    @if (canCreate)
    {
        <a asp-action="Create"
           class="btn btn-primary">
            + Create
        </a>
    }

    <button type="button"
            class="btn btn-secondary"
            onclick="window.history.back();">
        Back
    </button>
</div>

<!-- TABLE -->
<div class="table-responsive">
    <table class="table table-bordered table-hover">

    <thead class="table-dark">
        <tr>
            <th style="width: 5%;">SL</th>
            <th style="width: 20%;">Equipment Name</th>
            <th style="width: 10%;">Capacity</th>
            <th style="width: 15%;">Brand</th>
            <th style="width: 10%;">Model</th>
            <th style="width: 10%;">Serial No</th>
            <th style="width: 20%;">Current Location</th>
            <th style="width: 10%;" class="text-center">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            sl++;

            <tr>
                <td>@sl</td>
                <td>@item.EquipmentName</td>
                <td>@item.Capacity</td>
                <td>@item.Brand</td>
                <td>@item.Model</td>
                <td>@item.Slno</td>
                <td>@item.CurrentLocation</td>

                <td class="text-center">

                    <div class="d-flex justify-content-center gap-2">

                        @if (canEdit)
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.Eqid"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>
                        }

                        @if (canDelete)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@item.Eqid"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>
                        }

                    </div>

                </td>
            </tr>
        }
    </tbody>

    </table>
</div>

<!-- PAGINATION -->
<nav>
    <ul class="pagination justify-content-center">

        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link"
               asp-action="EquipmentDetailsList"
               asp-route-page="@(currentPage - 1)">
                Previous
            </a>
        </li>

        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="EquipmentDetailsList"
                   asp-route-page="@i">
                    @i
                </a>
            </li>
        }

        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
            <a class="page-link"
               asp-action="EquipmentDetailsList"
               asp-route-page="@(currentPage + 1)">
                Next
            </a>
        </li>

    </ul>
</nav>