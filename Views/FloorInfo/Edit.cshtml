@model UtilityManagement.Models.TblFloorInfo

@{
    ViewData["Title"] = "Edit Floor";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Edit Floor Information</h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit" method="post">
                        <input asp-for="Flid" type="hidden" />
                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row g-3">

                            <!-- Company -->
                            <div class="col-md-6">
                                <label asp-for="Comid" class="form-label">
                                    Company <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Comid"
                                        asp-items="ViewBag.CompanyList"
                                        class="form-select"
                                        id="CompanyId">
                                    <option value="">-- Select Company --</option>
                                </select>
                            </div>
                            <!-- Building -->
                            <div class="col-md-6">
                                <label asp-for="Bldid" class="form-label">
                                    Building <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Bldid"
                                        asp-items="ViewBag.BuildingList"
                                        class="form-select"
                                        id="BuildingId">
                                    <option value="">-- Select Building --</option>
                                </select>
                            </div>
                            <!-- Floor Name -->
                            <div class="col-md-6">
                                <label asp-for="Flname" class="form-label">
                                    Floor Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Flname" class="form-control" />
                                <span asp-validation-for="Flname" class="text-danger"></span>
                            </div>

                            <!-- Status -->
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">
                                    Status <span class="text-danger">*</span>
                                </label>

                                <select asp-for="Status" class="form-select">
                                    <option value="">-- Select Status --</option>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>

                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>

                            <!-- Remarks -->
                            <div class="col-md-6">
                                <label asp-for="Remarks" class="form-label">
                                    Remarks
                                </label>
                                <input asp-for="Remarks" class="form-control" />
                            </div>

                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="BuildingInfoList"
                               class="btn btn-outline-secondary">
                                ← Back
                            </a>

                            <button type="submit"
                                    class="btn btn-success px-4">
                                Update
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

<script>
    $(function () {

        $("#CompanyId").change(function () {

            var companyId = $(this).val();

            $("#BuildingId").empty();
            $("#BuildingId").append('<option value="">-- Select Building --</option>');

            if (companyId) {

                $.get("/Floor/GetBuildings",
                    { companyId: companyId },
                    function (data) {

                        $.each(data, function (i, item) {

                            $("#BuildingId").append(
                                $('<option></option>')
                                    .val(item.value)
                                    .text(item.text)
                            );
                        });

                    });
            }
        });

    });
</script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
