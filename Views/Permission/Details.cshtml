@model List<UtilityManagement.Models.TblUserPermission>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h4 class="mb-0">User Privilege Details</h4>

            <a asp-action="Index" class="btn btn-outline-primary btn-sm">
                ← Back
            </a>
        </div>
    </div>

    <!-- USER INFO -->
    @if (ViewBag.User != null)
    {
        <div class="alert alert-info shadow-sm">
            <strong>User:</strong> @ViewBag.User.UserName
        </div>
    }

    <!-- SUCCESS MESSAGE -->
@*     @if (TempData["msg"] != null)
    {
        <div class="alert alert-success shadow-sm">
            @TempData["msg"]
        </div>
    } *@

    @if (Model != null && Model.Count > 0)
    {
        <div class="card shadow-sm">

            <div class="card-header bg-dark text-white">
                Assigned Permissions
            </div>

            <div class="card-body p-0">

                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Module</th>
                                <th>Menu</th>
                                <th>Action</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <!-- MODULE -->
                                    <td class="fw-semibold">
                                        @item.Module?.ModuleName
                                    </td>

                                    <!-- MENU -->
                                    <td>
                                        @item.Menu?.MenuName
                                    </td>

                                    <!-- ACTION -->
                                    <td>
                                        <span class="badge bg-secondary">
                                            @item.Action?.ActionName
                                        </span>
                                    </td>

                                    <!-- STATUS -->
                                    <td class="text-center">
                                        @if (item.IsAllowed)
                                        {
                                            <span class="badge bg-success px-3 py-2">
                                                Allowed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2">
                                                Denied
                                            </span>
                                        }
                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    }
    else
    {
        <div class="alert alert-warning shadow-sm">
            No Privilege found for this user.
        </div>
    }

</div>