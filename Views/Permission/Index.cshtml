@model List<UtilityManagement.ViewModels.PermissionPageVm>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Privilege Management</h4>

            @if (ViewBag.SelectedUserId != null)
            {
                <span class="badge bg-primary">User Selected</span>
            }
        </div>
    </div>

    <style>
        body {
            background-color: #f4f6f9;
        }

        .main-wrapper {
            padding: 20px;
        }

        .navbar-brand {
            font-weight: 600;
        }
    </style>

    <!-- FILTER ROW -->
    <div class="row">

        <!-- USER SELECT -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <div class="card-body">

                    <form method="get">
                        <label class="form-label fw-bold">Select User</label>

                        <select name="userId"
                                class="form-select"
                                onchange="this.form.submit()">

                            <option value="" selected disabled>
                                Select user
                            </option>

                            @foreach (var user in ViewBag.Users)
                            {
                                <option value="@user.Id"
                                        selected="@(ViewBag.SelectedUserId == user.Id)">
                                    @user.UserName
                                </option>
                            }
                        </select>

                        <!-- preserve filters -->
                        <input type="hidden" name="moduleId" value="@Context.Request.Query["moduleId"]" />
                        <input type="hidden" name="menuId" value="@Context.Request.Query["menuId"]" />

                    </form>

                </div>
            </div>
        </div>

        <!-- MODULE SELECT -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <div class="card-body">

                    <form method="get">
                        <label class="form-label fw-bold">Select Module</label>

                        <select name="moduleId"
                                class="form-select"
                                onchange="this.form.submit()">

                            <option value="">All Modules</option>

                            @foreach (var module in ViewBag.Modules)
                            {
                                <option value="@module.ModuleId"
                                        selected="@(Context.Request.Query["moduleId"] == module.ModuleId.ToString())">
                                    @module.ModuleName
                                </option>
                            }

                        </select>

                        <!-- preserve filters -->
                        <input type="hidden" name="userId" value="@ViewBag.SelectedUserId" />
                        <input type="hidden" name="menuId" value="@Context.Request.Query["menuId"]" />

                    </form>

                </div>
            </div>
        </div>

        <!-- MENU SELECT -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <div class="card-body">

                    <form method="get">
                        <label class="form-label fw-bold">Select Menu</label>

                        <select name="menuId"
                                class="form-select"
                                onchange="this.form.submit()">

                            <option value="">All Menus</option>

                            @foreach (var menu in ViewBag.Menus)
                            {
                                <option value="@menu.MenuId"
                                        selected="@(Context.Request.Query["menuId"] == menu.MenuId.ToString())">
                                    @menu.MenuName
                                </option>
                            }

                        </select>

                        <!-- preserve filters -->
                        <input type="hidden" name="userId" value="@ViewBag.SelectedUserId" />
                        <input type="hidden" name="moduleId" value="@Context.Request.Query["moduleId"]" />

                    </form>

                </div>
            </div>
        </div>

    </div>

    <!-- TABLE -->
    @if (Model != null && Model.Count > 0)
    {
        <form asp-action="SaveData"
              asp-controller="Permission"
              method="post">

            <input type="hidden" name="userId" value="@ViewBag.SelectedUserId" />

            <div class="card shadow-sm">

                <div class="card-header bg-dark text-white">
                    <strong>Privilege Matrix</strong>
                </div>

                <div class="card-body p-0">

                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Module</th>
                                    <th>Menu</th>
                                    <th>Action</th>
                                    <th class="text-center">Allow</th>
                                </tr>
                            </thead>

                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr>

                                        <td class="fw-semibold">
                                            @Model[i].ModuleName
                                            <input type="hidden" name="model[@i].ModuleId" value="@Model[i].ModuleId" />
                                        </td>

                                        <td>
                                            @Model[i].MenuName
                                            <input type="hidden" name="model[@i].MenuId" value="@Model[i].MenuId" />
                                        </td>

                                        <td>
                                            <span class="badge bg-secondary">
                                                @Model[i].ActionName
                                            </span>
                                            <input type="hidden" name="model[@i].ActionId" value="@Model[i].ActionId" />
                                        </td>

                                        <td class="text-center">
                                            <div class="form-check form-switch d-flex justify-content-center">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="model[@i].IsAllowed"
                                                       value="true"
                                                       @(Model[i].IsAllowed ? "checked" : "") />
                                            </div>
                                        </td>

                                    </tr>
                                }
                            </tbody>

                        </table>

                    </div>

                </div>

                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-success">
                        Save Privilege
                    </button>
                </div>

            </div>

        </form>
    }
    else
    {
        <div class="alert alert-info shadow-sm">
            Please select a user and filters to view Privilege.
        </div>
    }

</div>