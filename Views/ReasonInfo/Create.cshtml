@model UtilityManagement.Models.TblReasonInfo

@{
    ViewData["Title"] = "Create Reason";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Add New Reason Information</h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row g-3">
                            <!-- Interruption Type -->
                            <div class="col-lg-6 col-md-6 col-sm-6">
                                <label asp-for="Itid" class="form-label">
                                    Interruption Type <span class="text-danger">*</span>
                                </label>
                                <select asp-for="Itid" asp-items="ViewBag.InterruptiotypeList" class="form-select">
                                    <option value="">-- Select type --</option>
                                </select>
                                <span asp-validation-for="Itid" class="text-danger"></span>
                            </div>
                            <!-- ReasonName -->
                            <div class="col-md-6">
                                <label asp-for="ReasonName" class="form-label">
                                    Reason Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="ReasonName" class="form-control" />
                                <span asp-validation-for="ReasonName" class="text-danger"></span>
                            </div>
                            <!-- Status -->
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label">
                                    Status <span class="text-danger">*</span>
                                </label>

                                <select asp-for="Status" class="form-select">
                                    <option value="">-- Select Status --</option>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select>

                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>

                            <!-- Remarks -->
                            <div class="col-md-6">
                                <label asp-for="Remarks" class="form-label">
                                    Remarks
                                </label>
                                <input asp-for="Remarks" class="form-control" />
                            </div>

                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="ReasonInfoList"
                               class="btn btn-outline-secondary">
                                ← Back
                            </a>

                            <button type="submit"
                                    class="btn btn-primary px-4">
                                Save
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
