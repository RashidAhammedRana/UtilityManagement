@model IEnumerable<UtilityManagement.Models.TblRebReadingInfo>

@{
    ViewData["Title"] = "REB Reading Info List";

    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;

    int pageSize = 15;
    int sl = (currentPage - 1) * pageSize;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);

    bool canCreate = ViewBag.CanCreate ?? false;
    bool canEdit = ViewBag.CanEdit ?? false;
    bool canDelete = ViewBag.CanDelete ?? false;
}

<h2 class="text-center">REB Reading Info List</h2>

<p class="text-muted text-center">
    Total Readings: <strong>@ViewBag.totalRebReadings</strong>
</p>

<!-- ACTION BUTTONS -->
<div class="d-flex justify-content-end mb-3 gap-2">

    @if (canCreate)
    {
        <a asp-action="Create"
           class="btn btn-primary">
            + Create
        </a>
    }

    <button type="button"
            class="btn btn-secondary"
            onclick="window.history.back();">
        Back
    </button>
</div>

<!-- TABLE -->
<div class="table-responsive">
    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th style="width: 5%;">SL</th>
                <th style="width: 10%;">Date</th>
                <th style="width: 10%;">Electricity Generation(Kwh)</th>
                <th style="width: 5%;">Running Hr</th>
                <th style="width: 10%;">BDT(tk/kwh)</th>
                <th style="width: 10%;">Others Consumable(TK)</th>
                <th style="width: 10%;">Troubleshooting(Tk)</th>
                <th style="width: 10%;">Service Charge(Tk)</th>
                <th style="width: 10%;">Repair Charge (Tk)</th>
                <th style="width: 5%;">Total(Tk)</th>
                <th style="width: 5%;">Tk/Kwh</th>
                <th style="width: 10%;" class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                sl++;

                <tr>
                    <td>@sl</td>
                    <td>@item.Trdate?.ToString("dd-MM-yyyy")</td>
                    <td>@item.ElecGen</td>
                    <td>@item.RunHr</td>
                    <td>@item.BdtKwh</td>
                    <td>@item.OtConsumable</td>
                    <td>@item.Troubleshoot</td>
                    <td>@item.ServiceCharge</td>
                    <td>@item.RepairCharge</td>
                    <td>@item.Total</td>
                    <td>@item.TkKwh</td>

                    <td class="text-center">

                        <div class="d-flex justify-content-center gap-2">

                            @if (canEdit)
                            {
                                <a asp-action="Edit"
                                   asp-route-id="@item.Trid"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>
                            }

                            @if (canDelete)
                            {
                                <a asp-action="Delete"
                                   asp-route-id="@item.Trid"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            }

                        </div>

                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>

<!-- PAGINATION -->
<nav aria-label="Pagination">
    <ul class="pagination justify-content-center flex-wrap">

        <!-- Previous -->
        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("RebReadingInfoList",new { page = currentPage - 1, searchString = ViewBag.SearchString })">
                Previous
            </a>
        </li>

        <!-- First Page -->
        @if (startPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   href="@Url.Action("RebReadingInfoList", new { page = 1, searchString = ViewBag.SearchString })">
                1
            </a>
        </li>

        @if (startPage > 2)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }
        }

        <!-- Current Range -->
        @for (int i = startPage; i <= endPage; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   href="@Url.Action("RebReadingInfoList",new { page = i, searchString = ViewBag.SearchString })">
                @i
            </a>
        </li>
                }

        <!-- Last Page -->
        @if (endPage < totalPages)
        {
            @if (endPage < totalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            <li class="page-item">
                <a class="page-link" href="@Url.Action("RebReadingInfoList", new { page = totalPages, searchString = ViewBag.SearchString })">
                @totalPages
            </a>
        </li>
                }

        <!-- Next -->
        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("RebReadingInfoList",new { page = currentPage + 1, searchString = ViewBag.SearchString })">
                Next
            </a>
        </li>

    </ul>
</nav>