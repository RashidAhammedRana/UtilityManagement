</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        // ================= CONSUMPTION =================
        const doshion51Cons = document.getElementById("Doshion51Cons");
        const doshion52Cons = document.getElementById("Doshion52Cons");
        const doScale65Cons = document.getElementById("DoScale65Cons");
        const h2so4Cons = document.getElementById("H2so4Cons");
        const dispergoCons = document.getElementById("DispergoCons");
        const na2s2o5Cons = document.getElementById("Na2s2o5Cons");
        const acidCleanerCons = document.getElementById("AcidCleanerCons");
        const alkalineCleanerCons = document.getElementById("AlkalineCleanerCons");
        // ================= COST =================
        const doshion51Cost = document.getElementById("Doshion51Cost");
        const doshion52Cost = document.getElementById("Doshion52Cost");
        const doScale65Cost = document.getElementById("DoScale65Cost");
        const h2so4Cost = document.getElementById("H2so4Cost");
        const dispergoCost = document.getElementById("DispergoCost");
        const na2s2o5Cost = document.getElementById("Na2s2o5Cost");
        const acidCleanerCost = document.getElementById("AcidCleanerCost");
        const alkalineCleanerCost = document.getElementById("AlkalineCleanerCost");
        // ================= BACKEND RATE =================
        const doshion51Rate = parseFloat('@ViewBag.Doshion51Rate') || 0;
        const doshion52Rate = parseFloat('@ViewBag.Doshion52Rate') || 0;
        const doScale65Rate = parseFloat('@ViewBag.DoScale65Rate') || 0;
        const h2so4Rate = parseFloat('@ViewBag.H2so4Rate') || 0;
        const dispergoRate = parseFloat('@ViewBag.DispergoRate') || 0;
        const na2s2o5Rate = parseFloat('@ViewBag.Na2s2o5Rate') || 0;
        const acidCleanerRate = parseFloat('@ViewBag.AcidCleanerRate') || 0;
        const alkalineCleanerRate = parseFloat('@ViewBag.AlkalineCleanerRate') || 0;
        // ================= SUMMARY =================
        const totalChemicalCost = document.getElementById("TotalChemicalCost");
        const serviceCharge = document.getElementById("ServiceCharge");
        const maintenanceCost = document.getElementById("MaintenanceCost");
        const manpowerSalary = document.getElementById("ManpowerSalary");
        const grandTotalCost = document.getElementById("GrandTotalCost");
        const effFlowRoSoft = document.getElementById("EffFlowRoSoft");
        const chemCostEffTreatment = document.getElementById("ChemCostEffTreatment");
        const dailyRoCost = document.getElementById("DailyRoCost");

        function calculateAll(){
            // ================= CONSUMPTION × RATE =================
            doshion51Cost.value =
                ((parseFloat(doshion51Cons.value)||0) * doshion51Rate).toFixed(2);
            doshion52Cost.value =
                ((parseFloat(doshion52Cons.value)||0) * doshion52Rate).toFixed(2);

            doScale65Cost.value =
                ((parseFloat(doScale65Cons.value)||0) * doScale65Rate).toFixed(2);
            h2so4Cost.value =
                ((parseFloat(h2so4Cons.value)||0) * h2so4Rate).toFixed(2);

            dispergoCost.value =
                ((parseFloat(dispergoCons.value)||0) * dispergoRate).toFixed(2);

            na2s2o5Cost.value =
                ((parseFloat(na2s2o5Cons.value)||0) * na2s2o5Rate).toFixed(2);
            acidCleanerCost.value =
                ((parseFloat(acidCleanerCons.value)||0) * acidCleanerRate).toFixed(2);
            alkalineCleanerCost.value =
                ((parseFloat(alkalineCleanerCons.value)||0) * alkalineCleanerRate).toFixed(2);

            // ================= TOTAL CHEMICAL COST =================

            let chemicalTotal =
                (parseFloat(doshion51Cost.value)||0)+
                (parseFloat(doshion52Cost.value)||0)+
                (parseFloat(doScale65Cost.value)||0)+
                (parseFloat(h2so4Cost.value)||0)+
                (parseFloat(dispergoCost.value)||0)+
                (parseFloat(na2s2o5Cost.value)||0)+
                (parseFloat(acidCleanerCost.value)||0)+
                (parseFloat(alkalineCleanerCost.value)||0);
            totalChemicalCost.value = chemicalTotal.toFixed(2);
            // ================= GRAND TOTAL =================
            let grandTotal =
                chemicalTotal +
                (parseFloat(serviceCharge.value)||0)+
                (parseFloat(maintenanceCost.value)||0)+
                (parseFloat(manpowerSalary.value)||0);
            grandTotalCost.value = grandTotal.toFixed(2);
            // ================= Tk/m3 =================
            let flow = parseFloat(effFlowRoSoft.value)||0;
            chemCostEffTreatment.value =
                flow > 0
                ? (chemicalTotal / flow).toFixed(2)
                : "0.00";
            dailyRoCost.value =
                flow > 0
                ? (grandTotal / flow).toFixed(2)
                : "0.00";
        }

        [
            doshion51Cons,
            doshion52Cons,
            doScale65Cons,
            h2so4Cons,
            dispergoCons,
            na2s2o5Cons,
            acidCleanerCons,
            alkalineCleanerCons,
            serviceCharge,
            maintenanceCost,
            manpowerSalary,
            effFlowRoSoft
        ].forEach(element=>{

            if(element){
                element.addEventListener("input",calculateAll);
            }

        });
        calculateAll();
    });

</script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
