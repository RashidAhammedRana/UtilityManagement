@model List<UtilityManagement.ViewModels.SidebarViewModel>

<style>
    .sidebar {
        width: 250px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background: #212529;
        display: flex;
        flex-direction: column;
    }

    .menu-container {
        flex: 1;
        overflow-y: auto;
    }

    .brand {
        text-align: center;
        padding: 15px;
        color: white;
        border-bottom: 1px solid #444;
    }

    .module-title {
        color: #bbb;
        font-size: 13px;
        padding: 10px 15px 5px;
        text-transform: uppercase;
    }

    .menu-link {
        display: block;
        color: #ddd;
        padding: 10px 20px;
        text-decoration: none;
        transition: 0.3s;
        font-size: 14px;
    }

        .menu-link:hover {
            background: #343a40;
            color: #fff;
        }

    .menu-icon {
        margin-right: 6px;
    }

    .logout-section {
        border-top: 1px solid #444;
        padding: 0;
    }

    .logout-btn {
        width: 100%;
        border: 1px solid #dc3545;
        background: transparent;
        color: #dc3545;
        padding: 14px 20px;
        font-weight: 500;
        text-align: left;
        transition: 0.25s ease;
        display: flex;
        align-items: center;
    }

        .logout-btn:hover {
            background: #dc3545;
            color: #fff;
        }
</style>

<div class="sidebar">

    <div class="brand">
        <img src="@Url.Content("~/images/cotton_logo.png")"
             style="width:160px;height:40px;object-fit:fill;" />

        <div style="margin-top:6px;font-weight:600;font-size:15px;">
            Utility Management
        </div>
    </div>

    <div class="menu-container">

        @foreach (var module in Model.GroupBy(x => x.ModuleName))
        {
            <div class="module-title">
                @module.Key
            </div>

            @foreach (var menu in module)
            {
                <a class="menu-link" href="@Url.Content(menu.Url)">
                    <i class="bi bi-circle menu-icon"></i>
                    @menu.MenuName
                </a>
            }
        }

    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="logout-section">
            <form method="post" asp-controller="Account" asp-action="Logout">
                <button type="submit" class="logout-btn">
                    <i class="bi bi-box-arrow-right menu-icon"></i>
                    Logout
                </button>
            </form>
        </div>
    }

</div>