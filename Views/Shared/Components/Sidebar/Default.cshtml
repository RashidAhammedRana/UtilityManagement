@model List<UtilityManagement.ViewModels.SidebarViewModel>

<style>
    .sidebar {
        width: 250px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background: #212529;
        display: flex;
        flex-direction: column;
        transition: all .3s ease;
        z-index: 1000;
    }

        .sidebar.collapsed {
            transform: translateX(-250px);
        }

    /* MAIN CONTENT MUST BE HERE */
    .main-content {
        margin-left: 250px;
        padding: 20px;
        transition: all .3s ease;
    }

        .main-content.full {
            margin-left: 0 !important;
        }

    .toggle-btn {
        position: fixed;
        top: 15px;
        left: 2px;
        z-index: 1100;
        border: none;
        background: #212529;
        color: white;
        padding: 8px 12px;
        border-radius: 5px;
        cursor: pointer;
        transition: .3s;
    }

        .toggle-btn:hover {
            background: #343a40;
        }

        .toggle-btn i {
            font-size: 18px;
        }

    .menu-container {
        flex: 1;
        overflow-y: auto;
    }

    .brand {
        text-align: center;
        padding: 15px;
        color: white;
        border-bottom: 1px solid #444;
    }

    .module-title {
        color: #bbb;
        font-size: 13px;
        padding: 10px 15px 5px;
        text-transform: uppercase;
    }

    .menu-link {
        display: block;
        color: #ddd;
        padding: 10px 20px;
        text-decoration: none;
        transition: .3s;
        font-size: 14px;
    }

        .menu-link:hover {
            background: #343a40;
            color: #fff;
        }

    .menu-icon {
        margin-right: 6px;
    }

    .logout-section {
        border-top: 1px solid #444;
        padding: 0;
    }

    .logout-btn {
        width: 100%;
        background: transparent;
        color: #dc3545;
        padding: 14px 20px;
        font-weight: 500;
        text-align: left;
        transition: .25s ease;
        display: flex;
        align-items: center;
        border: none;
    }

        .logout-btn:hover {
            background: #dc3545;
            color: #fff;
        }
</style>

@* <!-- TOGGLE BUTTON -->
<button id="sidebarToggle" class="toggle-btn" type="button">
    <i class="bi bi-list"></i>
</button> *@

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">

    <div class="brand">
        <!-- TOGGLE BUTTON -->
        @* <button id="sidebarToggle" class="toggle-btn">
            <i class="bi bi-list"></i>
        </button> *@
        <img src="@Url.Content("~/images/cotton_logo.png")"
             style="width:160px;height:40px;object-fit:fill;" />

        <div style="margin-top:6px;font-weight:600;font-size:15px;">
            Utility Management
        </div>
    </div>

    <div class="menu-container">

        @foreach (var module in Model.GroupBy(x => x.ModuleName))
        {
            <div class="module-title">
                @module.Key
            </div>

            @foreach (var menu in module)
            {
                <a class="menu-link" href="@Url.Content(menu.Url)">
                    <i class="bi bi-chevron-right menu-icon"></i>
                    @menu.MenuName
                </a>
            }
        }

    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="logout-section">
            <form method="post"
                  asp-controller="Account"
                  asp-action="Logout">

                <button type="submit" class="logout-btn">
                    <i class="bi bi-box-arrow-right menu-icon"></i>
                    Logout
                </button>

            </form>
        </div>
    }

</div>

