@model List<UtilityManagement.ViewModels.SidebarViewModel>

<style>
    .sidebar {
        width: 250px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background: #212529;
        display: flex;
        flex-direction: column;
        transition: all .3s ease;
        z-index: 1000;
    }

        .sidebar.collapsed {
            transform: translateX(-250px);
        }

    .main-content {
        margin-left: 250px;
        padding: 20px;
        transition: all .3s ease;
    }

        .main-content.full {
            margin-left: 0 !important;
        }

    .menu-container {
        flex: 1;
        overflow-y: auto;
    }

    .brand {
        text-align: center;
        padding: 15px;
        color: white;
        border-bottom: 1px solid #444;
    }

    /* Module Header */
    .module-header {
        color: #ddd;
        padding: 12px 18px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        border-bottom: 1px solid #343a40;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: .3s;
    }

        .module-header:hover {
            background: #343a40;
            color: #fff;
        }

        .module-header.active {
            background: #0d6efd;
            color: #fff;
        }

    .module-arrow {
        transition: transform .3s;
    }

    .module-header.active .module-arrow {
        transform: rotate(90deg);
    }

    /* Module Menu */
    .module-menu {
        display: none;
        background: #2b3035;
    }

        .module-menu.show {
            display: block;
        }

    .menu-link {
        display: block;
        color: #ddd;
        padding: 10px 35px;
        text-decoration: none;
        transition: .3s;
        font-size: 14px;
    }

        .menu-link:hover {
            background: #495057;
            color: #fff;
        }

    .menu-icon {
        margin-right: 8px;
    }

    .logout-section {
        border-top: 1px solid #444;
    }

    .logout-btn {
        width: 100%;
        background: transparent;
        color: #dc3545;
        padding: 14px 20px;
        font-weight: 500;
        text-align: left;
        border: none;
        display: flex;
        align-items: center;
        transition: .3s;
    }

        .logout-btn:hover {
            background: #dc3545;
            color: white;
        }
</style>

<div class="sidebar" id="sidebar">

    <div class="brand">
        <img src="@Url.Content("~/images/cotton_logo.png")"
             style="width:160px;height:40px;object-fit:fill;" />

        <div style="margin-top:6px;font-weight:600;font-size:15px;">
            Utility Management
        </div>
    </div>

    <div class="menu-container">

        @{
            int i = 0;
        }

        @foreach (var module in Model.GroupBy(x => x.ModuleName))
        {
            var id = "module_" + i;

            <div class="module-header"
                 onclick="toggleModule('@id', this)">
                <span>@module.Key</span>
                <i class="bi bi-chevron-right module-arrow"></i>
            </div>

            <div id="@id" class="module-menu">

                @foreach (var menu in module)
                {
                    <a class="menu-link" href="@Url.Content(menu.Url)">
                        <i class="bi bi-chevron-right menu-icon"></i>
                        @menu.MenuName
                    </a>
                }

            </div>

            i++;
        }

    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="logout-section">
            <form method="post"
                  asp-controller="Account"
                  asp-action="Logout">

                <button type="submit" class="logout-btn">
                    <i class="bi bi-box-arrow-right menu-icon"></i>
                    Logout
                </button>

            </form>
        </div>
    }

</div>

<script>
    function toggleModule(id, element) {

        const menus = document.querySelectorAll(".module-menu");
        const headers = document.querySelectorAll(".module-header");

        const currentMenu = document.getElementById(id);

        const isOpen = currentMenu.classList.contains("show");

        // Close all modules
        menus.forEach(menu => menu.classList.remove("show"));
        headers.forEach(header => header.classList.remove("active"));

        // Open only if it wasn't already open
        if (!isOpen) {
            currentMenu.classList.add("show");
            element.classList.add("active");
        }
    }
</script>