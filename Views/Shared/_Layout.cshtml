<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
        }

        /* SIDEBAR WRAPPER */
        .sidebar-wrapper {
            width: 250px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            transition: .3s;
        }

            .sidebar-wrapper.hidden {
                transform: translateX(-250px);
            }

        .main-content {
            margin-left: 250px;
            width: calc(100% - 250px);
            padding: 20px;
            transition: .3s;
        }

        .sidebar-collapsed {
            margin-left: 0 !important;
        }

        .sidebar-hidden {
            transform: translateX(-250px);
        }

        .sidebar-hidden {
            transform: translateX(-250px);
        }

        /* MAIN CONTENT */
        .main-content {
            margin-left: 250px;
            padding: 20px;
            transition: all .3s ease;
        }

            .main-content.full {
                margin-left: 0;
                width: 100%;
            }

        /* RESPONSIVE */
        @@media(max-width: 768px) {
            .sidebar-wrapper {
                position: relative;
                width: 100%;
                height: auto;
            }

            .main-content {
                margin-left: 0;
            }
        }

        input[readonly] {
            background-color: #e9ecef !important; /* standard bootstrap grey */
            color: #495057 !important; /* normal readable text */
            border: 1px solid #ced4da !important;
            cursor: not-allowed;
        }

        input[readonly]:focus {
            box-shadow: none !important;
            outline: none !important;
        }
    </style>

</head>

<body>
    <!-- TOGGLE BUTTON -->
    <button id="sidebarToggle" class="toggle-btn" type="button">
        <i class="bi bi-list"></i>
    </button>

    <!-- SIDEBAR -->
    <div id="sidebarWrapper" class="sidebar-wrapper">
        @await Component.InvokeAsync("Sidebar")
    </div>

    <!-- MAIN CONTENT -->
    <div id="mainContent" class="main-content">
        @RenderBody()
    </div>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {

            var successMessage = '@(TempData["SuccessMessage"] ?? "")';
            var errorMessage = '@(TempData["ErrorMessage"] ?? "")';

            toastr.options = {
                closeButton: true,
                progressBar: true,
                positionClass: "toast-top-right",
                timeOut: 1000
            };

            if (successMessage.trim().length > 0) {
                toastr.success(successMessage, "Success");
            }

            if (errorMessage.trim().length > 0) {
                toastr.error(errorMessage, "Error");
            }

        });


        document.getElementById("sidebarToggle")
        .addEventListener("click", function () {

            document.getElementById("sidebarWrapper")
                .classList.toggle("hidden");

            document.getElementById("mainContent")
                .classList.toggle("full");
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>