@model UtilityManagement.Models.TblSolarReadingInfo

@{
    ViewData["Title"] = "Create Solar Reading";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Add New Solar Reading</h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="row g-3">

                            <!-- Trdate -->
                            <div class="col-md-6">
                                <label asp-for="Trdate" class="form-label">
                                    Date <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Trdate" type="date" class="form-control" />

                                <span asp-validation-for="Trdate" class="text-danger"></span>
                            </div>

                            <!-- Equipment -->
                            <div class="col-md-6">
                                <label asp-for="Eqid" class="form-label">
                                    Equipment <span class="text-danger">*</span>
                                </label>

                                <select asp-for="Eqid" asp-items="ViewBag.EquipmentList" class="form-select">
                                    <option value="">-- Select Equipment --</option>
                                </select>

                                <span asp-validation-for="Eqid" class="text-danger"></span>
                            </div>

                            <!-- ServiceChargeCost -->
                            <div class="col-md-6">
                                <label asp-for="ServiceChargeCost" class="form-label">
                                    Service Charge Cost<span class="text-danger">*</span>
                                </label>
                                <input asp-for="ServiceChargeCost" class="form-control" />
                                <span asp-validation-for="ServiceChargeCost" class="text-danger"></span>
                            </div>

                            <!-- SparePartsCost -->
                            <div class="col-md-6">
                                <label asp-for="SparePartsCost" class="form-label">
                                    Spare Parts Cost <span class="text-danger">*</span>
                                </label>
                                <input asp-for="SparePartsCost" class="form-control" />
                                <span asp-validation-for="SparePartsCost" class="text-danger"></span>
                            </div>

                            <!-- TotalCost -->
                            <div class="col-md-6">
                                <label asp-for="TotalCost" class="form-label">
                                    Total Cost<span class="text-danger">*</span>
                                </label>
                                <input asp-for="TotalCost" class="form-control" readonly/>
                                <span asp-validation-for="TotalCost" class="text-danger"></span>
                            </div>

                            <!-- GenerationKwh -->
                            <div class="col-md-6">
                                <label asp-for="GenerationKwh" class="form-label">
                                    Generation Kwh<span class="text-danger">*</span>
                                </label>
                                <input asp-for="GenerationKwh" class="form-control" />
                                <span asp-validation-for="GenerationKwh" class="text-danger"></span>
                            </div>
                            <!-- PerUnitGenCost -->
                            <div class="col-md-6">
                                <label asp-for="PerUnitGenCost" class="form-label">
                                    Per Unit Gen. Cost<span class="text-danger">*</span>
                                </label>
                                <input asp-for="PerUnitGenCost" class="form-control"readonly />
                                <span asp-validation-for="PerUnitGenCost" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="SolarReadingInfoList"
                               class="btn btn-outline-secondary">
                                ← Back
                            </a>

                            <button type="submit"
                                    class="btn btn-primary px-4">
                                Save Reading
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const serviceChargeCost = document.getElementById("ServiceChargeCost");
        const sparePartsCost = document.getElementById("SparePartsCost");
        const totalCost = document.getElementById("TotalCost");

        const GenerationKwh = document.getElementById("GenerationKwh");
        const perUnitGenCost = document.getElementById("PerUnitGenCost");

        function num(el) {
            return parseFloat(el?.value) || 0;
        }

        function calculateValues() {

            // Total Cost = Service Charge + Spare Parts
            const total =
                num(serviceChargeCost) +
                num(sparePartsCost);

            totalCost.value = total.toFixed(2);

            // Per Unit Generation Cost = Total / Generation Kwh
            const generation = num(GenerationKwh);

            perUnitGenCost.value =
                generation > 0
                    ? (total / generation).toFixed(4)
                    : "0.0000";
        }

        [
            serviceChargeCost,
            sparePartsCost,
            GenerationKwh
        ].forEach(el => {
            if (el) {
                el.addEventListener("input", calculateValues);
            }
        });

        calculateValues();
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
