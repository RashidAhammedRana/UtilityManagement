@model UtilityManagement.Models.TblWtpPlanCostInfo

@{
    ViewData["Title"] = "Delete Reading";
}

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-7">

            <div class="card shadow border-danger">

                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Delete Confirmation</h5>
                </div>

                <div class="card-body">

                    <div class="text-center py-3">

                        <i class="bi bi-exclamation-triangle-fill text-danger fs-1"></i>

                        <h5 class="text-danger mt-3">
                            Are you sure you want to delete this record?
                        </h5>

                    </div>

                    <form asp-action="Delete" method="post">

                        <input type="hidden" asp-for="Trid" />

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="WtpPlanCostInfoList"
                               class="btn btn-secondary">
                                No
                            </a>

                            <button type="submit"
                                    class="btn btn-danger">
                                Yes
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>