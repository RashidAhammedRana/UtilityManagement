</div>

<link rel="stylesheet" href="~/css/WtpWaterConsumption.css" asp-append-version="true" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/WtpWaterConsumption.js"></script>
}
