                                    </label>
                                    <input asp-for="HotConsLab" class="form-control" />
                                    <span asp-validation-for="HotConsLab" class="text-danger"></span>
                                </div>
                                <!-- HotConsOthersArea -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
