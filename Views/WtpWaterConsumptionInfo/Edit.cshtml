                                    </label>
                                    <input asp-for="HotConsDyeingFin" class="form-control" />
                                    <span asp-validation-for="HotConsDyeingFin" class="text-danger"></span>
                                </div>
                                <!-- HotConsWashing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="HotConsWashing" class="form-label">
                                        Washing Consumtion<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="HotConsWashing" class="form-control" />
                                    <span asp-validation-for="HotConsWashing" class="text-danger"></span>
                                </div>
                                <!-- HotConsSeamlessDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="HotConsSeamlessDyeing" class="form-label">
                                        Seamless Dyeing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="HotConsSeamlessDyeing" class="form-control" />
                                    <span asp-validation-for="HotConsSeamlessDyeing" class="text-danger"></span>
                                </div>
                                <!-- HotConsLab -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
