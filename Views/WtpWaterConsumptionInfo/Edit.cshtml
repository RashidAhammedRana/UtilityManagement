@model UtilityManagement.Models.TblWtpWaterConsumptionInfo

@{
    ViewData["Title"] = "Edit WTP Water Consumption Info";
}

<div class="container-fluid mt-3 edit-page">

    <div class="row">
        <div class="col-md-12">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Edit WTP Water Consumption Info</h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit" method="post">
                        <input asp-for="Trid" hidden/>
                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="stepper edit-stepper">

                            <div id="stepCircle1" class="step active edit-step">
                                1
                            </div>

                            <div id="stepLine1" class="line"></div>

                            <div id="stepCircle2" class="step edit-step">
                                2
                            </div>
                            <div id="stepLine2" class="line"></div>

                            <div id="stepCircle3" class="step edit-step">
                                3
                            </div>
                            <div id="stepLine3" class="line"></div>

                            <div id="stepCircle4" class="step edit-step">
                                4
                            </div>
                        </div>

                        <div id="step1" class="wizard-step active">

                            <div class="section-title">
                                Raw Water Consumption
                            </div>

                            <hr class="border-success opacity-50">


                            <!-- Common Information -->
                            <div class="row g-3 mb-4">

                                <!-- Date -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="Trdate" class="form-label">
                                        Date <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="Trdate"
                                           type="date"
                                           class="form-control" />

                                    <span asp-validation-for="Trdate"
                                          class="text-danger"></span>
                                </div>


                                <!-- Equipment -->
                                <div class="col-lg-3 col-md-4 col-sm-6">

                                    <label asp-for="Eqid" class="form-label">
                                        Equipment <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="Eqid"
                                            asp-items="ViewBag.EquipmentList"
                                            class="form-select">

                                        <option value="">
                                            -- Select Equipment --
                                        </option>

                                    </select>

                                    <span asp-validation-for="Eqid"
                                          class="text-danger"></span>

                                </div>

                            </div>

                            <div class="row g-3">

                                <!-- RawConsGarments -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsGarments" class="form-label">
                                        Garments Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsGarments" class="form-control" />
                                    <span asp-validation-for="RawConsGarments" class="text-danger"></span>
                                </div>

                                <!-- RawConsDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsDyeing" class="form-label">
                                        Dyeing Consumption <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsDyeing" class="form-control" />
                                    <span asp-validation-for="RawConsDyeing" class="text-danger"></span>
                                </div>

                                <!-- DslLtrHr -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsDyeingFin" class="form-label">
                                        Dyeing Finishing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsDyeingFin" class="form-control" />
                                    <span asp-validation-for="RawConsDyeingFin" class="text-danger"></span>
                                </div>
                                <!-- RawConsPrinting -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsPrinting" class="form-label">
                                        Printing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsPrinting" class="form-control" />
                                    <span asp-validation-for="RawConsPrinting" class="text-danger"></span>
                                </div>
                                <!-- RawConsUtilityArea -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsUtilityArea" class="form-label">
                                        Utility Area Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsUtilityArea" class="form-control" />
                                    <span asp-validation-for="RawConsUtilityArea" class="text-danger"></span>
                                </div>
                                <!-- RawConsWashing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsWashing" class="form-label">
                                        Washing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsWashing" class="form-control" />
                                    <span asp-validation-for="RawConsWashing" class="text-danger"></span>
                                </div>

                                <!-- RawConsSeamlessDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsSeamlessDyeing" class="form-label">
                                        Seamless Dyeing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsSeamlessDyeing" class="form-control" />
                                    <span asp-validation-for="RawConsSeamlessDyeing" class="text-danger"></span>
                                </div>
                                <!-- RawConsLab -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsLab" class="form-label">
                                        Lab Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsLab" class="form-control" />
                                    <span asp-validation-for="RawConsLab" class="text-danger"></span>
                                </div>
                                <!-- RawConsGardening -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsGardening" class="form-label">
                                        Gardening Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsGardening" class="form-control" />
                                    <span asp-validation-for="RawConsGardening" class="text-danger"></span>
                                </div>
                                <!-- RawConsWashroomOthers -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsWashroomOthers" class="form-label">
                                        All Washroom & Others Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsWashroomOthers" class="form-control" />
                                    <span asp-validation-for="RawConsWashroomOthers" class="text-danger"></span>
                                </div>
                                <!-- RawConsKnittingArea -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsKnittingArea" class="form-label">
                                        Knitting Area Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsKnittingArea" class="form-control" />
                                    <span asp-validation-for="RawConsKnittingArea" class="text-danger"></span>
                                </div>
                                <!-- RawConsOthersArea -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsOthersArea" class="form-label">
                                        Others Area Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsOthersArea" class="form-control" />
                                    <span asp-validation-for="RawConsOthersArea" class="text-danger"></span>
                                </div>
                                <!-- RawConsBackWash -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsBackWash" class="form-label">
                                        Back Wash Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsBackWash" class="form-control" />
                                    <span asp-validation-for="RawConsBackWash" class="text-danger"></span>
                                </div>
                                <!-- RawConsTotal -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RawConsTotal" class="form-label">
                                        Total Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RawConsTotal" class="form-control" readonly />
                                    <span asp-validation-for="RawConsTotal" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mt-4">

                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        onclick="history.back();">
                                    ← Back
                                </button>

                                <button type="button"
                                        class="btn btn-success"
                                        id="nextBtn1">
                                    Next →
                                </button>

                            </div>

                        </div>
                        <div id="step2" class="wizard-step">

                            <div class="section-title">
                                Soft Water Consumption
                            </div>
                            <hr class="border-success opacity-50">

                            <div class="row g-3">
                                <!-- SoftConsDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="SoftConsDyeing" class="form-label">
