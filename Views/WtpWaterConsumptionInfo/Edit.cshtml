                                    </label>
                                    <input asp-for="SoftConsWashing" class="form-control" />
                                    <span asp-validation-for="SoftConsWashing" class="text-danger"></span>
                                </div>
                                <!-- SoftConsSeamlessDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="SoftConsSeamlessDyeing" class="form-label">
                                        Seamless Dyeing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SoftConsSeamlessDyeing" class="form-control" />
                                    <span asp-validation-for="SoftConsSeamlessDyeing" class="text-danger"></span>
                                </div>
                                <!-- SoftConsLab -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="SoftConsLab" class="form-label">
                                        Lab Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SoftConsLab" class="form-control" />
                                    <span asp-validation-for="SoftConsLab" class="text-danger"></span>
                                </div>
                                <!-- SoftConsOthersArea -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="SoftConsOthersArea" class="form-label">
                                        Others Area Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SoftConsOthersArea" class="form-control" />
                                    <span asp-validation-for="SoftConsOthersArea" class="text-danger"></span>
                                </div>
                                <!-- SoftConsTotal -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="SoftConsTotal" class="form-label">
                                        Total Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="SoftConsTotal" class="form-control" readonly />
                                    <span asp-validation-for="SoftConsTotal" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mt-4">

                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        id="previousBtn2">
                                    ← Previous
                                </button>

                                <button type="button"
                                        class="btn btn-success"
                                        id="nextBtn2">
                                    Next →
                                </button>

                            </div>
                        </div>
                        <div id="step3" class="wizard-step">

                            <div class="section-title">
                                RO Water Consumption
                            </div>
                            <hr class="border-success opacity-50">

                            <div class="row g-3">
                                <!-- RoConsDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsDyeing" class="form-label">
                                        Dyeing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsDyeing" class="form-control" />
                                    <span asp-validation-for="RoConsDyeing" class="text-danger"></span>
                                </div>
                                <!-- RoConsDyeingFin -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsDyeingFin" class="form-label">
                                        Dyeing Finishing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsDyeingFin" class="form-control" />
                                    <span asp-validation-for="RoConsDyeingFin" class="text-danger"></span>
                                </div>
                                <!-- RoConsWashing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsWashing" class="form-label">
                                        Washing Consumtion<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsWashing" class="form-control" />
                                    <span asp-validation-for="RoConsWashing" class="text-danger"></span>
                                </div>
                                <!-- RoConsSeamlessDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsSeamlessDyeing" class="form-label">
                                        Seamless Dyeing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsSeamlessDyeing" class="form-control" />
                                    <span asp-validation-for="RoConsSeamlessDyeing" class="text-danger"></span>
                                </div>
                                <!-- RoConsLab -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsLab" class="form-label">
                                        Lab Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsLab" class="form-control" />
                                    <span asp-validation-for="RoConsLab" class="text-danger"></span>
                                </div>
                                <!-- RoConsOthersArea -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsOthersArea" class="form-label">
                                        Others Area Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsOthersArea" class="form-control" />
                                    <span asp-validation-for="RoConsOthersArea" class="text-danger"></span>
                                </div>
                                <!-- RoConsTotal -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="RoConsTotal" class="form-label">
                                        Total Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="RoConsTotal" class="form-control" readonly />
                                    <span asp-validation-for="RoConsTotal" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mt-4">

                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        id="previousBtn3">
                                    ← Previous
                                </button>

                                <button type="button"
                                        class="btn btn-success"
                                        id="nextBtn3">
                                    Next →
                                </button>

                            </div>
                        </div>

                        <div id="step4" class="wizard-step">

                            <div class="section-title">
                                Hot Water Consumption
                            </div>
                            <hr class="border-success opacity-50">

                            <div class="row g-3">
                                <!-- HotConsDyeing -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="HotConsDyeing" class="form-label">
                                        Dyeing Consumption<span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="HotConsDyeing" class="form-control" />
                                    <span asp-validation-for="HotConsDyeing" class="text-danger"></span>
                                </div>
                                <!-- HotConsDyeingFin -->
                                <div class="col-lg-3 col-md-4 col-sm-6">
                                    <label asp-for="HotConsDyeingFin" class="form-label">
